{
  "name": "all_in_one_sec",
  "version": "1.0.0",
  "description": "An all-in-one information security utility platform",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "watch": "sass --watch scss:public/css",
    "prepare": "lefthook install"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DoanDac-Grik/all-in-one-security.git"
  },
  "keywords": [
    "all in one security",
    "g0d b0iz",
    "autopentest",
    "check safe link"
  ],
  "author": "doanvandac, letuananh, nguyenquanghuy",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/DoanDac-Grik/all-in-one-security/issues"
  },
  "homepage": "https://github.com/DoanDac-Grik/all-in-one-security#readme",
  "dependencies": {
    "axios": "^1.16.1",
    "child-process-promise": "^2.2.1",
    "connect-flash": "^0.1.1",
    "dotenv": "^17.4.2",
    "ejs": "^5.0.2",
    "exec-sh": "^0.4.0",
    "express": "^5.2.1",
    "express-ejs-layouts": "^2.5.1",
    "express-session": "^1.19.0",
    "mongoose": "^9.6.2",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "node-fetch": "^3.3.2",
    "node-virustotal": "^0.1.3",
    "password-generator": "^3.0.0",
    "wysiwyg-editor-node-sdk": "^5.2.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/connect-flash": "^0.0.40",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.8.0",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "froala-editor": "^5.2.0",
    "lefthook": "^2.1.6",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "sass": "^1.89.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
